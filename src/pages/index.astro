	<body>
		<div class="background">
			<div class="intro">
				<div class="row">
					<div class="block"></div>
					<div class="names">
						<p class="h name" id="firstname">𝔄rmie</p>
						<p class="h name" id="lastname">ℜysmakhanov</p>
					</div>
					<div class="contacts">
						<p class="t">ar21@williams.edu</p>
					</div>
					<div class="block"></div>
				</div>
				<div class="block"></div>
				<div class="block"></div>
				<div class="row">
					<div class="box no-left center">
						<p class="t bio">
							My name is Arman (Armie) Rysmakhanov. I am a
							freshman at Williams College studying Mathematics
							and Computer Science. Here are my software
							projects/projects with code components.
						</p>
					</div>
					<div class="box no-right no-left">
						<ul class="t menu">
							<li><a href="#proj1">social map</a></li>
							<li><a href="#proj2">diary web app</a></li>
							<li>
								<a href="#proj3">handwriting teaching device</a>
							</li>
							<li><a href="#proj4">mobile app</a></li>
							<li>
								<a href="#proj5"
									>statistics/geography project</a>
							</li>
						</ul>
					</div>
